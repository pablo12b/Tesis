# Variables de entorno para el proyecto Tesis - Bienestar Estudiantil
# Copia este archivo a .env y rellena tus valores reales

# ====== BASE DE DATOS PostgreSQL ======
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tesis_bienestar

# ====== BACKEND (Express) ======
PORT=5000
NODE_ENV=development

# ====== GROQ API (Para análisis con IA) ======
GROQ_API_KEY=tu_api_key_de_groq_aqui

# ====== REDES SOCIALES (Para scraping) ======
# Credentials para login automático
TIKTOK_EMAIL=tu_email@example.com
TIKTOK_PASSWORD=tu_contraseña_tiktok

INSTAGRAM_EMAIL=tu_email@example.com
INSTAGRAM_PASSWORD=tu_contraseña_instagram

FACEBOOK_EMAIL=tu_email@example.com
FACEBOOK_PASSWORD=tu_contraseña_facebook

# ====== CONFIGURACIÓN DE SCRAPING ======
SCRAPE_TIMEOUT=60000
SCRAPE_HEADLESS=false
SCRAPE_SLOW_MO=0
